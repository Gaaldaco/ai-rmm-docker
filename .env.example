# ─── Required ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional: Database ──────────────────────────────────────────────────────
POSTGRES_DB=ai_remote_service
POSTGRES_USER=postgres
POSTGRES_PORT=5432

# ─── Optional: Redis ─────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Optional: API ───────────────────────────────────────────────────────────
API_PORT=8080
# Public URL agents use to reach the API (shown in install scripts)
API_URL=http://your-server-ip:8080
# GitHub repo for agent binary downloads (org/repo format)
GITHUB_REPO=

# ─── Optional: Web ───────────────────────────────────────────────────────────
WEB_PORT=3000
# Set if the frontend is accessed from a different URL than the API
VITE_API_URL=
# Allowed CORS origins (comma-separated)
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=
